# Copy this file to backend/.env and fill only what you need.
# Do not commit backend/.env.

# Groq Decision Agent
GROQ_API_KEY_1=replace_with_your_key
# GROQ_API_KEY_2=replace_with_optional_extra_key
GROQ_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile

# Optional: GPT-OSS on Groq for model comparison experiments
GPT_OSS_MAX_COMPLETION_TOKENS=6911
GPT_OSS_REASONING_EFFORT=low

# Optional: review model for deterministic report critique
REVIEW_LLM_BASE_URL=https://api.groq.com/openai/v1
REVIEW_LLM_MODEL=llama-3.3-70b-versatile

# Optional: OpenRouter experiments
# OPENROUTER_API_KEY=replace_with_your_key
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Optional: direct DeepSeek experiments
# DEEPSEEK_API_KEY=replace_with_your_key
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# Real trading is intentionally not implemented/enabled in V2.
# Keep any future real-trading switch false by default.
# REAL_TRADING_ENABLED=false
